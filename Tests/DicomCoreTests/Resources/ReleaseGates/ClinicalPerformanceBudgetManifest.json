{
  "version": 2,
  "issue": 1436,
  "conformanceManifest": "ClinicalCodecConformanceManifest.json",
  "privacyPolicy": "Reports contain fixture identifiers, aggregate timings, counters, and environment data only; never patient metadata or pixel payloads.",
  "requiredStages": [
    "decode",
    "gpuUpload",
    "progressiveFrame",
    "snapshot",
    "peakMemory"
  ],
  "requiredWorkflowMetrics": [
    "thumbnailLatency",
    "firstVisibleFrame",
    "finalFrame",
    "cineFrameP50P95P99",
    "zoomROILatency",
    "panCancellationLatency",
    "workAvoided",
    "cacheTransitions",
    "jpipLayerProgress",
    "jpipByteAccounting",
    "cpuAndMemory",
    "metalResources",
    "copiesAndTemporaryIO",
    "commandBuffers"
  ],
  "benchmarkModes": [
    "cold-sdk-first-call",
    "prewarmed-first-clinical-call",
    "warm-isolated",
    "warm-sustained",
    "concurrent-clinical-workload",
    "fallback-path"
  ],
  "tiers": [
    {
      "id": "pr-smoke",
      "purpose": "Small deterministic correctness-first signal on every pull request.",
      "hostPolicy": "CI host class; compare only within the same environment fingerprint."
    },
    {
      "id": "nightly",
      "purpose": "Sustained, concurrent, cache, partial-decode, and progressive workload coverage.",
      "hostPolicy": "Pinned nightly host where available."
    },
    {
      "id": "release",
      "purpose": "Full clinical corpus and release-configuration absolute plus relative gates.",
      "hostPolicy": "Pinned release host and device class."
    },
    {
      "id": "manual-device",
      "purpose": "Device-only Metal, energy, and thermal observations kept separate from host baselines.",
      "hostPolicy": "Named physical device; never mixed with simulator or CLI baselines."
    }
  ],
  "reportFormats": [
    "json",
    "csv",
    "markdown"
  ],
  "buildConfigurations": [
    "debug",
    "release"
  ],
  "warningRatio": 0.9,
  "comparisonProfile": {
    "referenceDeviceClass": "Apple Silicon local developer or pinned CI host",
    "comparisonRule": "Correctness must pass first. Apply absolute warning/failure budgets, then relative warning/failure deltas only when every comparison key matches.",
    "relativeWarningPercent": 10.0,
    "relativeFailurePercent": 20.0,
    "requiredResultEnvironmentFields": [
      "deviceName",
      "osVersion",
      "architecture",
      "modelIdentifier",
      "buildConfiguration",
      "benchmarkMode",
      "fixtureID",
      "tier",
      "commandLineStartupIncluded"
    ]
  },
  "scenarios": [
